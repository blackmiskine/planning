# Server
PORT=3001
NODE_ENV=development

# Database
DB_PATH=./data/planning.sqlite

# JWT
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRES_IN=24h

# App
DEFAULT_MAX_HOURS_DAY=10
DEFAULT_MAX_HOURS_WEEK=44
DEFAULT_MAX_HOURS_MONTH=176

# Optimizer
OPTIMIZER_SEED=42

# Backup
BACKUP_DIR=./data/backups
BACKUP_MAX_COUNT=10

# Logging
LOG_LEVEL=info
