{
  "version": 2,
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "packages/frontend/dist",
  "installCommand": "rm -f package-lock.json && npm install && npm run build:shared",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "node_modules/sql.js/dist/**"
    }
  }
}
